---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tours } from "../data/tours.js";
---

<BaseLayout title="Tour Packages | Chetan Holidays">
<section class="page-banner">
  <div class="container">
    <h1>Our Tour Packages</h1>
    <p>Explore India & International Destinations with Chetan Holidays</p>
  </div>
</section>

<section class="tours-page">
  <div class="container">

    <div class="tour-grid">

      {tours.map((tour) => (

        <div class="tour-card">

          <img
            src={tour.image}
            alt={tour.title}
            loading="lazy"
          />

          <div class="tour-content">

            <span class="tour-badge">
              {tour.badge}
            </span>

            <h3>{tour.title}</h3>

            <p>{tour.duration}</p>

            <p>
              Starting from
              <strong> ₹ {tour.price}</strong>
            </p>

            <a
              href={`/tours/${tour.slug}`}
              class="btn btn-primary"
            >
              View Details
            </a>

          </div>

        </div>

      ))}

    </div>

  </div>
</section>

</BaseLayout>