---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tours } from "../data/tours.js";
---

<BaseLayout title="Tour Packages | Chetan Holidays">

  <!-- Hero -->
  <section class="tours-hero">
    <div class="hero-overlay">
      <div class="container hero-content">

        <span class="hero-badge">
          Trusted Family Tours Since 2005
        </span>

        <h1>Explore Our Tour Packages</h1>

        <p>
          Discover unforgettable family holidays across India and international
          destinations with comfortable travel, quality hotels and memorable
          experiences.
        </p>

        <a href="#tour-grid" class="btn btn-primary">
          Explore Tours
        </a>

      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="tour-stats">
    <div class="container">

      <div class="stats-grid">

        <div class="stats-item">
          <div class="stats-icon">⭐</div>
          <h3>5000+</h3>
          <p>Happy Tourists</p>
        </div>

        <div class="stats-item">
          <div class="stats-icon">🚌</div>
          <h3>20+</h3>
          <p>Destinations</p>
        </div>

        <div class="stats-item">
          <div class="stats-icon">🏨</div>
          <h3>Quality</h3>
          <p>Hotels</p>
        </div>

        <div class="stats-item">
          <div class="stats-icon">👨‍👩‍👧‍👦</div>
          <h3>Family</h3>
          <p>Group Tours</p>
        </div>

      </div>

    </div>
  </section>

  <!-- Tour Cards -->
  <section class="tours-page">

    <div class="container">

      <div id="tour-grid" class="tour-grid">

  {tours.map((tour) => (

    <article class="tour-card">

      <div class="tour-image">

        <img
          src={tour.image}
          alt={tour.title}
          loading="lazy"
        />

        <span class="tour-badge">
          {tour.badge}
        </span>

      </div>

      <div class="tour-content">

        <h3>{tour.title}</h3>

        <div class="tour-duration">
          📅 {tour.duration}
        </div>

        <div class="tour-price">

          <small>Starting from</small>

          <h4>₹ {tour.price}</h4>

        </div>

        <a
          href={`/tours/${tour.slug}`}
          class="btn btn-primary"
        >
          View Tour →
        </a>

      </div>

    </article>

  ))}

</div>

    </div>

  </section>

</BaseLayout>