---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TourHero from "../../components/TourHero.astro";
import StickyBookingBar from "../../components/StickyBookingBar.astro";
import QuickInfo from "../../components/QuickInfo.astro";
import TourItinerary from "../../components/TourItinerary.astro";
import TourHotels from "../../components/TourHotels.astro";
import TourGallery from "../../components/TourGallery.astro";
import TourIncludes from "../../components/TourIncludes.astro";
import TourEnquiry from "../../components/TourEnquiry.astro";
import TourTerms from "../../components/TourTerms.astro";
import DownloadPdfModal from "../../components/DownloadPdfModal.astro";
import { jagannath } from "../../data/jagannath.js";
---

<BaseLayout
  title="Jagannath Puri Tour Package from Mumbai | 6N/7D | Chetan Holidays"
  description="Book the Jagannath Puri - Konark - Bhubaneswar - Kolkata - Gangasagar Tour Package from Mumbai/Pune with Chetan Holidays. 6 Nights / 7 Days with train travel, hotels, meals and guided sightseeing."
>

<TourHero tour={jagannath} />
<StickyBookingBar tour={jagannath} />
<QuickInfo tour={jagannath} />
<section class="tour-highlights">

  <div class="container">

    <h2 class="section-title">
      Tour Highlights
    </h2>

    <div class="highlight-grid">

      {jagannath.highlights.map((item) => (

        <div class="highlight-card">

          <div class="highlight-icon">
            {item.icon}
          </div>

          <h3>{item.title}</h3>

          <p>{item.description}</p>

        </div>

      ))}

    </div>

  </div>

</section>
<TourItinerary tour={jagannath} />
<TourHotels tour={jagannath} />
<TourGallery tour={jagannath} />
<TourIncludes tour={jagannath} />
<section class="tour-highlights">

  <div class="container">

    <h2 class="section-title">
      Important Information
    </h2>

    <ul>

      {jagannath.notes.map((note) => (

        <li>{note}</li>

      ))}

    </ul>

  </div>

</section>
<TourEnquiry tour={jagannath} />

<TourTerms />
<DownloadPdfModal tour={jagannath} />
</BaseLayout>
