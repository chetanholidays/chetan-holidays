---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TourHero from "../../components/TourHero.astro";
import StickyBookingBar from "../../components/StickyBookingBar.astro";
import QuickInfo from "../../components/QuickInfo.astro";
import TourItinerary from "../../components/TourItinerary.astro";
import TourHotels from "../../components/TourHotels.astro";
import TourGallery from "../../components/TourGallery.astro";
import TourIncludes from "../../components/TourIncludes.astro";
import TourEnquiry from "../../components/TourEnquiry.astro";
import TourTerms from "../../components/TourTerms.astro";
import DownloadPdfModal from "../../components/DownloadPdfModal.astro";
import TourPdfTemplate from "../../components/TourPdfTemplate.astro";
import { chandigarhShimlaManaliDharamshalaDalhousie } from "../../data/chandigarh-shimla-manali-dharamshala-dalhousie.js";
---

<BaseLayout
  title="Chandigarh Shimla Manali Dharamshala Dalhousie Tour Package | Chetan Holidays"
  description="Book the Chandigarh - Shimla - Manali - Dharamshala - Dalhousie Family Tour with Chetan Holidays. Comfortable hotels, AC 3 Tier train travel, meals and guided sightseeing across Himachal Pradesh."
>

<TourHero tour={chandigarhShimlaManaliDharamshalaDalhousie} />
<StickyBookingBar tour={chandigarhShimlaManaliDharamshalaDalhousie} />
<QuickInfo tour={chandigarhShimlaManaliDharamshalaDalhousie} />
<section class="tour-highlights">

  <div class="container">

    <h2 class="section-title">
      Tour Highlights
    </h2>

    <div class="highlight-grid">

      {chandigarhShimlaManaliDharamshalaDalhousie.highlights.map((item) => (

        <div class="highlight-card">

          <div class="highlight-icon">
            {item.icon}
          </div>

          <h3>{item.title}</h3>

          <p>{item.description}</p>

        </div>

      ))}

    </div>

  </div>

</section>
<TourItinerary tour={chandigarhShimlaManaliDharamshalaDalhousie} />
<TourHotels tour={chandigarhShimlaManaliDharamshalaDalhousie} />
<TourGallery tour={chandigarhShimlaManaliDharamshalaDalhousie} />
<TourIncludes tour={chandigarhShimlaManaliDharamshalaDalhousie} />
<section class="tour-highlights">

  <div class="container">

    <h2 class="section-title">
      Important Information
    </h2>

    <ul>

      {chandigarhShimlaManaliDharamshalaDalhousie.notes.map((note) => (

        <li>{note}</li>

      ))}

    </ul>

  </div>

</section>
<TourEnquiry tour={chandigarhShimlaManaliDharamshalaDalhousie} />

<TourTerms />
<DownloadPdfModal tour={chandigarhShimlaManaliDharamshalaDalhousie} />
<TourPdfTemplate tour={chandigarhShimlaManaliDharamshalaDalhousie} />

</BaseLayout>
