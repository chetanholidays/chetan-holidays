---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TourHero from "../../components/TourHero.astro";
import StickyBookingBar from "../../components/StickyBookingBar.astro";
import QuickInfo from "../../components/QuickInfo.astro";
import TourItinerary from "../../components/TourItinerary.astro";
import TourHotels from "../../components/TourHotels.astro";
import TourGallery from "../../components/TourGallery.astro";
import TourIncludes from "../../components/TourIncludes.astro";
import TourEnquiry from "../../components/TourEnquiry.astro";
import TourTerms from "../../components/TourTerms.astro";
import DownloadPdfModal from "../../components/DownloadPdfModal.astro";
import TourPdfTemplate from "../../components/TourPdfTemplate.astro";
import { kashmir } from "../../data/kashmir.js";
---

<BaseLayout
  title="Kashmir Family Tour Package from Mumbai | 6N/7D | Chetan Holidays"
  description="Book the Kashmir Family Tour Package from Mumbai with Chetan Holidays. 6 Nights / 7 Days covering Srinagar, Gulmarg, Pahalgam and Sonmarg. Comfortable hotels, meals and sightseeing included."
>

<TourHero tour={kashmir} />
<StickyBookingBar tour={kashmir} />
<QuickInfo tour={kashmir} />
<section class="tour-highlights">

  <div class="container">

    <h2 class="section-title">
      Tour Highlights
    </h2>

    <div class="highlight-grid">

      {kashmir.highlights.map((item) => (

        <div class="highlight-card">

          <div class="highlight-icon">
            {item.icon}
          </div>

          <h3>{item.title}</h3>

          <p>{item.description}</p>

        </div>

      ))}

    </div>

  </div>
  

</section>
<TourItinerary tour={kashmir} />
<TourHotels tour={kashmir} />
<TourGallery tour={kashmir} />
<TourIncludes tour={kashmir} />
<TourEnquiry tour={kashmir} />

<TourTerms />
<DownloadPdfModal tour={kashmir} />
<TourPdfTemplate tour={kashmir} />

</BaseLayout>