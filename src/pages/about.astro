---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About Us | Chetan Holidays"
  description="Learn about Chetan Holidays, a trusted family tour operator since 2005, offering comfortable group tours with homely food and Marathi-friendly travel experiences."
>

<!-- ==========================================
     HERO
========================================== -->

<section class="about-hero">

    <div class="container">

        <div class="about-hero-content">

            <span class="section-tag">
                About Chetan Holidays
            </span>

            <h1>
                Creating Memorable
                <br />
                Family Holidays
                <br />
                Since <span>2005</span>
            </h1>

            <p>
                For over two decades, Chetan Holidays has been bringing
                families together through carefully planned group tours across
                India with comfort, care and unforgettable memories.
            </p>

            <a href="/tours" class="btn-secondary">
                Explore Our Tours
            </a>

        </div>

    </div>

</section>

<!-- ==========================================
     FOUNDERS
========================================== -->

<section class="about-founders section">

    <div class="container">

        <div class="section-heading">

            <span class="section-tag">
                Our Founders
            </span>

            <h2>
                Meet the People Behind Chetan Holidays
            </h2>

            <p>
                Built on passion, trust and genuine hospitality,
                Chetan Holidays has proudly served families across
                Maharashtra since 2005.
            </p>

        </div>

        <div class="founders-grid">

            <!-- Anita -->

            <article class="founder-card">

                <img
                    src="/images/about/anita.jpg"
                    alt="Mrs. Anita Arun Ghandat"
                    loading="lazy"
                />

                <div class="content">

                    <h3>
                        Mrs. Anita Arun Ghandat
                    </h3>

                    <span>
                        Founder & Tour Director
                    </span>

                    <p>
                        Known for her warmth, hospitality and personal attention,
                        she ensures every traveller feels safe, comfortable and
                        cared for throughout the journey.
                    </p>

                </div>

            </article>

            <!-- Centre -->

            <article class="founder-card featured">

                <img
                    src="/images/founders.png"
                    alt="Chetan Holidays Founders"
                    loading="lazy"
                />

                <div class="content">

                    <h3>
                        Chetan Holidays
                    </h3>

                    <span>
                        Trusted Family Tours Since 2005
                    </span>

                    <p>
                        For more than 20 years, Chetan Holidays has created
                        memorable family holidays across India with carefully
                        planned itineraries, quality accommodations, delicious
                        homely meals and personalised service.
                    </p>

                </div>

            </article>

            <!-- Arun -->

            <article class="founder-card">

                <img
                    src="/images/about/arun.jpg"
                    alt="Mr. Arun Ghandat"
                    loading="lazy"
                />

                <div class="content">

                    <h3>
                        Mr. Arun Ghandat
                    </h3>

                    <span>
                        Founder & Operations Head
                    </span>

                    <p>
                        With years of experience in tour planning and operations,
                        he ensures every holiday is organised with comfort,
                        reliability and attention to detail.
                    </p>

                </div>

            </article>

        </div>

    </div>

</section>

<!-- ==========================================
     STATISTICS
========================================== -->

<section class="about-stats">

    <div class="container">

        <div class="stats-grid">

            <div class="stat">
                <h2>20+</h2>
                <p>Years of Excellence</p>
            </div>

            <div class="stat">
                <h2>5000+</h2>
                <p>Happy Travellers</p>
            </div>

            <div class="stat">
                <h2>100+</h2>
                <p>Successful Tours</p>
            </div>

            <div class="stat">
                <h2>Since</h2>
                <p>2005</p>
            </div>

        </div>

    </div>

</section>
<!-- ==========================================
     OUR STORY
========================================== -->

<section class="about-story section">

    <div class="container">

        <div class="section-heading center">

            <span class="section-tag">
                Our Story
            </span>

            <h2>
                Travel Like Family
            </h2>

        </div>

        <div class="story-content">

            <p>
                Founded in <strong>2005</strong> by
                <strong>Mrs. Anita Arun Ghandat</strong> and
                <strong>Mr. Arun Ghandat</strong>,
                Chetan Holidays was built on one simple belief —
                every journey should feel like travelling with family.
            </p>

            <p>
                What began as a small dream has grown into one of
                Maharashtra's trusted family tour companies. We specialise
                in thoughtfully planned group tours where comfort,
                safety and genuine hospitality come before everything else.
            </p>

            <p>
                From the majestic mountains of Kashmir to the spiritual
                temples of South India and the colourful landscapes of
                Rajasthan, we have helped thousands of travellers create
                memories with the people they love most.
            </p>

            <p>
                Today, after serving over <strong>5,000 happy travellers</strong>,
                our mission remains unchanged—to provide every guest with
                comfortable travel, quality accommodation, delicious homely
                food and personalised care from the beginning of the tour
                until they safely return home.
            </p>

        </div>

    </div>

</section>

<!-- ==========================================
     WHY CHOOSE US
========================================== -->

<section class="about-features section">

    <div class="container">

        <div class="section-heading center">

            <span class="section-tag">
                Why Choose Us
            </span>

            <h2>
                Why Families Trust Chetan Holidays
            </h2>

            <p>
                Every tour is carefully planned to provide comfort,
                reliability and memorable experiences for travellers
                of every age.
            </p>

        </div>

        <div class="feature-grid">

            <article class="feature-card">

                <div class="feature-icon">👨‍👩‍👧‍👦</div>

                <h3>Family-Friendly Tours</h3>

                <p>
                    Designed especially for families, couples,
                    children and senior citizens who want a
                    relaxed and enjoyable holiday.
                </p>

            </article>

            <article class="feature-card">

                <div class="feature-icon">🍛</div>

                <h3>Homely Food</h3>

                <p>
                    Fresh, hygienic and delicious meals prepared
                    with care so you always feel at home while
                    travelling.
                </p>

            </article>

            <article class="feature-card">

                <div class="feature-icon">🚌</div>

                <h3>Comfortable Travel</h3>

                <p>
                    Well-planned itineraries, quality hotels and
                    reliable transport for a smooth travel
                    experience.
                </p>

            </article>

            <article class="feature-card">

                <div class="feature-icon">🌍</div>

                <h3>Marathi Group Tours</h3>

                <p>
                    Travel with like-minded Marathi families from
                    across Maharashtra in a friendly and welcoming
                    atmosphere.
                </p>

            </article>

            <article class="feature-card">

                <div class="feature-icon">🤝</div>

                <h3>20+ Years of Trust</h3>

                <p>
                    Thousands of satisfied travellers continue to
                    choose us year after year because of our
                    commitment to quality and service.
                </p>

            </article>

            <article class="feature-card">

                <div class="feature-icon">❤️</div>

                <h3>Personal Care</h3>

                <p>
                    Every tour is personally managed with attention
                    to comfort, safety and creating unforgettable
                    memories for every guest.
                </p>

            </article>

        </div>

    </div>

</section>
<!-- ==========================================
     OUR PROMISE
========================================== -->

<section class="about-promise section">

    <div class="container">

        <div class="promise-box">

            <span class="section-tag">
                Our Promise
            </span>

            <h2>
                Every Journey Begins With Trust
            </h2>

            <p>
                At Chetan Holidays, every traveller is treated like family.
                From carefully planned itineraries and comfortable
                accommodations to delicious homely meals and personalised
                care, we are committed to making every journey safe,
                enjoyable and truly memorable. Your trust inspires
                everything we do.
            </p>

        </div>

    </div>

</section>

<!-- ==========================================
     CALL TO ACTION
========================================== -->

<section class="about-cta section">

    <div class="container">

        <div class="cta-box">

            <span class="section-tag">
                Start Your Next Journey
            </span>

            <h2>
                Ready for Your Next Family Holiday?
            </h2>

            <p>
                Join thousands of happy travellers who have explored India
                with Chetan Holidays. Let us help you create unforgettable
                memories with your family.
            </p>

            <div class="cta-buttons">

                <a href="/tours" class="btn-secondary">
                    Explore Tours
                </a>

                <a href="/contact" class="btn-secondary">
                    Contact Us
                </a>

            </div>

        </div>

    </div>

</section>

</BaseLayout>