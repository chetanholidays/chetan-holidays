---
const { tour } = Astro.props;
---

<div
  id="pdf-content"
  style="
position:fixed;
left:-9999px;
top:0;
width:794px;
background:#fff;
color:#000;
padding:40px;
font-family:Arial,sans-serif;
display:block;
visibility:visible;
"
>
<div style="text-align:center;margin-bottom:30px;">

  <div
  style="
    display:flex;
    align-items:center;
    justify-content:center;
    gap:18px;
    margin-bottom:25px;
  "
>
  <img
    src="/logo.png"
    alt="Chetan Holidays"
    style="height:90px;"
  />

  <div style="text-align:left;">
    <div
      style="
        font-size:34px;
        font-weight:700;
        color:#0F172A;
        line-height:1.1;
      "
    >
      Chetan Holidays
    </div>

    <div
      style="
        font-size:15px;
        color:#666;
        margin-top:4px;
      "
    >
      Trusted Family Tours Since 2005
    </div>
  </div>
</div>

  <img
    src={tour.heroImage}
    alt={tour.title}
    style="
      width:100%;
      height:260px;
      object-fit:cover;
      border-radius:14px;
      margin-bottom:25px;
    "
  />

  <h1
    style="
      margin:0;
      color:#0F172A;
      font-size:34px;
    "
  >
    {tour.title}
  </h1>

  <p
    style="
      font-size:20px;
      color:#666;
      margin:10px 0;
    "
  >
    {tour.duration}
  </p>

  <p
    style="
      color:#777;
      margin-bottom:20px;
    "
  >
    {tour.subtitle}
  </p>

  <div
    style="
      background:#F8F8F8;
      border-radius:12px;
      padding:18px;
      display:flex;
      justify-content:space-between;
      gap:20px;
    "
  >

    <div>
      <strong>Starting From</strong><br/>
      ₹ {tour.adultPrice} / Adult
    </div>

    <div>
      <strong>Child Price</strong><br/>
      ₹ {tour.childPrice}
    </div>

  </div>

</div>    

  <hr />

  <h2>Tour Highlights</h2>

  <ul>
    {tour.highlights.map((item) => (
      <li>
        <strong>{item.title}</strong> - {item.description}
      </li>
    ))}
  </ul>

  <hr />

  <h2>Day Wise Itinerary</h2>

  {tour.itinerary.map((day) => (
    <div style="margin-bottom:18px;">
      <h3>{day.day} - {day.title}</h3>

      <ul>
        {day.activities.map((activity) => (
          <li>{activity}</li>
        ))}
      </ul>
    </div>
  ))}

  <hr />

  <h2>Package Includes</h2>

  <ul>
    {tour.includes.map((item) => (
      <li>{item}</li>
    ))}
  </ul>

  <h2>Package Excludes</h2>

  <ul>
    {tour.excludes.map((item) => (
      <li>{item}</li>
    ))}
  </ul>

  <hr />

  <div style="text-align:center;margin-top:40px;">
    <h3>Chetan Holidays</h3>
    <p>📞 +91 9967534278</p>
    <p>🌐 www.chetanholidays.com</p>
  </div>

</div>